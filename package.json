{
  "name": "clipboard-hero",
  "version": "1.0.0",
  "description": "AI-powered clipboard history manager — local-first, open source",
  "main": "dist/main/main.js",
  "scripts": {
    "build:ts": "tsc",
    "copy:assets": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/styles.css dist/renderer/",
    "prebuild": "rm -rf dist",
    "build": "npm run build:ts && npm run copy:assets",
    "start": "npm run build && electron .",
    "rebuild": "node scripts/rebuild.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "clipboard",
    "manager",
    "electron",
    "ai",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
